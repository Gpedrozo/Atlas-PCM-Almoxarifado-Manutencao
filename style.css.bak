/* =========================================================
   ATLAS INDÃšSTRIA ELETRODOMÃ‰STICOS â€” PCM Almoxarifado
   style.css â€” Sistema de Design Industrial Premium Clean
   Tipografia: Inter | Suporte a Tema Claro / Escuro
   ========================================================= */

@import url('https://fonts.googleapis.com/css2family=Inter:wght@400;500;600;700;800&display=swap');

:root {
  /* â”€â”€ PALETA SUAVE REFINADA â”€â”€ */
  --primary:       #2563EB;   /* azul limpo */
  --primary-dark:  #1D4ED8;   /* azul escuro */
  --primary-light: #60A5FA;   /* azul suave */
  /* â”€â”€ ATLAS BRAND COLORS â”€â”€ */
  --brand-orange:  #F7941D;   /* laranja Atlas (exato da logo) */
  --brand-blue:    #1B3A8A;   /* azul Atlas (exato da logo) */
  --accent:        #F7941D;   /* laranja principal */
  --accent-dark:   #D97706;
  --accent-light:  #FFF7ED;
  --danger:        #EF4444;
  --success:       #22C55E;
  --warning:       #F59E0B;
  --info:          #3B82F6;

  /* BACKGROUNDS ULTRA SUAVE */
  --bg:            #F1F4F8;   /* cinza azulado muito suave */
  --card:          #FFFFFF;
  --sidebar-bg:    #111827;   /* quase preto elegante */
  --sidebar-text:  #9CA3AF;
  --sidebar-hover: rgba(255,255,255,0.06);
  --sidebar-active:rgba(255,255,255,0.05);
  --sidebar-accent:#F7941D;

  /* TEXTO */
  --text:          #1E293B;   /* azul profundo suave */
  --text-muted:    #64748B;
  --border:        #E2E8F0;
  --border-light:  #F1F5F9;

  /* SOMBRAS ULTRA SUAVES */
  --shadow:        0 1px 4px rgba(15,23,42,0.04), 0 1px 2px rgba(15,23,42,0.03);
  --shadow-md:     0 4px 12px rgba(15,23,42,0.07);
  --shadow-lg:     0 8px 28px rgba(15,23,42,0.10);

  /* BORDAS ARREDONDADAS */
  --radius:        10px;
  --radius-lg:     14px;
  --radius-sm:     6px;

  /* TIPOGRAFIA */
  --font:          'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --font-mono:     'SF Mono', 'Monaco', 'Menlo', monospace;

  /* TAMANHOS â€” ESCALA REDUZIDA 25% */
  --text-xs:       10px;
  --text-sm:       12px;
  --text-base:     13px;
  --text-lg:       15px;
  --text-xl:       18px;
  --text-2xl:      22px;
  --text-3xl:      28px;
}

/* =========================================================
   REFATORACAO VISUAL 2026 — Design system Atlas PCM
   Camada final de normalizacao visual azul/laranja.
   ========================================================= */

:root {
  --brand-blue: #1B3A8A;
  --brand-orange: #F7941D;
  --primary: #2563EB;
  --primary-dark: #1B3A8A;
  --primary-light: #93B4FF;
  --accent: #F7941D;
  --accent-dark: #D97706;
  --accent-light: #FFF7ED;
  --success: #22C55E;
  --warning: #F59E0B;
  --danger: #EF4444;
  --info: #3B82F6;
  --bg: #F1F4F8;
  --card: #FFFFFF;
  --text: #1E293B;
  --text-muted: #64748B;
  --border: #E2E8F0;
  --border-light: #EEF2F7;
  --sidebar-bg: #101827;
  --radius: 8px;
  --radius-lg: 10px;
  --radius-sm: 6px;
  --shadow: 0 1px 3px rgba(15,23,42,.06), 0 1px 2px rgba(15,23,42,.04);
  --shadow-md: 0 8px 22px rgba(15,23,42,.08);
  --shadow-lg: 0 18px 50px rgba(15,23,42,.18);
}

[data-theme="dark"] {
  --brand-blue: #93C5FD;
  --brand-orange: #FB923C;
  --primary: #60A5FA;
  --primary-dark: #3B82F6;
  --primary-light: #93C5FD;
  --accent: #FB923C;
  --accent-light: rgba(251,146,60,.12);
  --bg: #0D1117;
  --card: #161B22;
  --text: #E6EDF3;
  --text-muted: #9AA4B2;
  --border: #273244;
  --border-light: #212A39;
  --sidebar-bg: #080E19;
}

body {
  background:
    linear-gradient(180deg, rgba(27,58,138,.045), rgba(247,148,29,.025) 260px, transparent 520px),
    var(--bg);
}

.main-content {
  background: transparent;
}

.breadcrumb {
  margin: 12px 12px 8px;
  border: 1px solid var(--border-light);
}

.topbar {
  min-height: 58px;
  height: auto;
  border: 1px solid var(--border-light);
  border-bottom: 3px solid var(--brand-blue);
  box-shadow: var(--shadow);
}

.topbar::before {
  content: "";
  width: 4px;
  align-self: stretch;
  border-radius: 999px;
  background: var(--brand-orange);
  margin-right: 2px;
}

.topbar-title {
  color: var(--primary-dark);
  font-size: 18px;
  line-height: 1.15;
}

[data-theme="dark"] .topbar-title {
  color: var(--text);
}

.topbar-subtitle {
  line-height: 1.35;
}

.page-body {
  padding: 0 20px 24px;
}

.card {
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow);
}

.card:hover {
  border-color: var(--border);
  box-shadow: var(--shadow-md);
}

.card-title {
  color: var(--primary-dark);
  font-size: 14px;
}

[data-theme="dark"] .card-title {
  color: var(--text);
}

.btn {
  min-height: 34px;
  border-radius: 8px;
}

.btn-primary {
  background: var(--primary-dark);
  color: #fff;
}

.btn-primary:hover {
  background: var(--primary);
}

.btn-outline {
  background: #fff;
  border-color: rgba(27,58,138,.28);
  color: var(--primary-dark);
}

.btn-outline:hover {
  background: var(--primary-dark);
  border-color: var(--primary-dark);
}

[data-theme="dark"] .btn-outline {
  background: rgba(255,255,255,.03);
  color: var(--primary-light);
  border-color: rgba(147,197,253,.35);
}

.btn-warning {
  background: var(--brand-orange);
}

.btn-icon,
.btn-theme {
  width: 36px;
  height: 36px;
  border-radius: 8px;
}

.filter-bar,
.toolbar-card,
.card[style*="margin-bottom"][style*="padding:14px"],
.card[style*="padding:14px 18px"] {
  border-left: 4px solid var(--brand-orange);
}

.search-bar {
  min-height: 38px;
  background: #F8FAFC;
  border-color: var(--border);
}

[data-theme="dark"] .search-bar {
  background: rgba(255,255,255,.035);
}

input[type="text"],
input[type="number"],
input[type="email"],
input[type="password"],
input[type="date"],
select,
textarea {
  min-height: 36px;
  border-radius: 8px;
}

input:focus,
select:focus,
textarea:focus {
  border-color: var(--brand-blue);
  box-shadow: 0 0 0 3px rgba(27,58,138,.10);
}

table {
  border-collapse: separate;
  border-spacing: 0;
}

thead th {
  background: #F8FAFC;
  color: #475569;
  border-bottom: 1px solid var(--border);
}

[data-theme="dark"] thead th {
  background: rgba(255,255,255,.035);
  color: var(--text-muted);
}

tbody td {
  border-bottom: 1px solid var(--border-light);
}

tbody tr:last-child td {
  border-bottom: none;
}

tbody tr:hover {
  background: rgba(27,58,138,.045);
}

.badge {
  border-radius: 999px;
  border: 1px solid transparent;
}

.badge-low,
.badge-PENDENTE {
  background: var(--accent-light);
  color: var(--accent-dark);
  border-color: rgba(247,148,29,.18);
}

.badge-pending,
.badge-SOLICITADO {
  background: #EFF6FF;
  color: var(--primary-dark);
  border-color: rgba(27,58,138,.14);
}

.badge-ok,
.badge-approved,
.badge-RECEBIDO {
  border-color: rgba(34,197,94,.18);
}

.badge-critical,
.badge-rejected,
.badge-REJEITADO {
  border-color: rgba(239,68,68,.18);
}

.modal-overlay {
  padding: 14px;
  backdrop-filter: blur(4px);
}

.modal {
  border-radius: 12px;
  border: 1px solid var(--border-light);
}

.modal-header {
  border-bottom: 1px solid var(--border-light);
  padding-bottom: 12px;
}

.modal-title {
  color: var(--primary-dark);
  font-size: 15px;
}

[data-theme="dark"] .modal-title {
  color: var(--text);
}

.modal-footer {
  border-top: 1px solid var(--border-light);
  padding-top: 14px;
}

.tabs,
.module-tabs {
  background: transparent;
  border-bottom: 1px solid var(--border);
  gap: 4px;
}

.tab-btn,
.module-tab {
  border-radius: 8px 8px 0 0;
}

.tab-btn.active,
.module-tab.active {
  color: var(--primary-dark);
  border-bottom-color: var(--brand-orange);
  background: rgba(247,148,29,.08);
}

.empty-state {
  padding: 34px 18px;
  color: var(--text-muted);
}

.empty-state .icon {
  opacity: .35;
}

/* Padrao de formulario longo em wizard visual sem quebrar JS existente */
.req-secao,
.form-section,
.wizard-section {
  position: relative;
  background: #fff;
  border: 1px solid var(--border-light);
  border-left: 4px solid var(--brand-orange);
  border-radius: 10px;
  box-shadow: var(--shadow);
}

[data-theme="dark"] .req-secao,
[data-theme="dark"] .form-section,
[data-theme="dark"] .wizard-section {
  background: var(--card);
}

.req-secao-titulo,
.form-section-title,
.wizard-section-title {
  color: var(--primary-dark);
}

[data-theme="dark"] .req-secao-titulo,
[data-theme="dark"] .form-section-title,
[data-theme="dark"] .wizard-section-title {
  color: var(--primary-light);
}

/* Estoque: drawer responsivo sem reescrever a logica atual */
.stock-layout {
  align-items: stretch;
}

.stock-detail-panel .card {
  border-top: 3px solid var(--brand-orange);
}

.stock-item-row.selected {
  background: rgba(27,58,138,.08) !important;
  box-shadow: inset 3px 0 0 var(--brand-orange);
}

.stock-bar {
  background: #E2E8F0;
}

.stock-bar-fill.ok {
  background: var(--success);
}

.stock-bar-fill.low {
  background: var(--brand-orange);
}

.stock-bar-fill.critical {
  background: var(--danger);
}

/* Dashboard: hierarquia mais executiva */
.dashboard-kpi-grid,
.kpi-grid {
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
}

.kpi-card,
.kpi-card-large,
.status-card,
.alert-group {
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow);
}

.kpi-card::before,
.kpi-card-large::before {
  content: "";
  width: 4px;
  align-self: stretch;
  border-radius: 999px;
  background: var(--brand-orange);
  flex: 0 0 4px;
}

.kpi-icon.orange,
.kpi-large-icon.orange {
  background: var(--accent-light);
  color: var(--brand-orange);
}

/* Consertos: reduz visualmente a complexidade das abas antigas */
.module-tabs {
  margin: 0 12px 14px;
  padding: 0 8px;
  border: 1px solid var(--border-light);
  border-radius: 10px;
  background: var(--card);
  box-shadow: var(--shadow);
}

.module-tab {
  margin-bottom: 0;
  border-bottom-width: 3px;
}

.consertos-hero,
.consertos-filterbar,
.consertos-kpi-strip .conserto-kpi,
.kanban-col,
.kanban-card {
  border-radius: 10px;
  border-color: var(--border-light);
}

.consertos-hero {
  border-top: 3px solid var(--brand-orange);
}

.consertos-eyebrow,
.kanban-num {
  color: var(--primary-dark);
}

[data-theme="dark"] .consertos-eyebrow,
[data-theme="dark"] .kanban-num {
  color: var(--primary-light);
}

.kanban-card {
  border-left-color: var(--brand-blue);
}

.kanban-card.is-overdue {
  border-left-color: var(--danger);
}

.kanban-card.is-done {
  border-left-color: var(--success);
}

/* Relatorios/configuracoes como areas de trabalho, nao pagina solta */
.report-grid,
.config-layout {
  align-items: start;
}

.report-menu,
.config-menu {
  position: sticky;
  top: 86px;
}

/* Mobile/tablet */
@media (max-width: 900px) {
  .topbar {
    margin: 0 8px 12px;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
  }

  .topbar::before {
    display: none;
  }

  .topbar-actions {
    width: 100%;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .page-body {
    padding: 0 12px 18px;
  }

  .stock-layout {
    display: block;
  }

  .stock-detail-panel {
    width: auto;
    position: fixed;
    inset: auto 10px 10px 10px;
    max-height: 72vh;
    z-index: 95;
    overflow: auto;
  }

  .stock-detail-panel:has(#painel-detalhe:empty) {
    display: none;
  }

  .report-grid,
  .config-layout {
    display: block;
  }

  .report-menu,
  .config-menu {
    position: static;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    margin-bottom: 14px;
  }
}

/* =========================================================
   REFATORACAO VISUAL 2026 — camada final de override
   Mantem azul/laranja da marca acima dos estilos antigos.
   ========================================================= */

:root {
  --brand-blue: #1B3A8A;
  --brand-orange: #F7941D;
  --primary: #2563EB;
  --primary-dark: #1B3A8A;
  --primary-light: #93B4FF;
  --accent: #F7941D;
  --accent-dark: #D97706;
  --accent-light: #FFF7ED;
  --bg: #F1F4F8;
  --card: #FFFFFF;
  --text: #1E293B;
  --text-muted: #64748B;
  --border: #E2E8F0;
  --border-light: #EEF2F7;
  --sidebar-bg: #101827;
  --radius: 8px;
  --radius-lg: 10px;
  --shadow: 0 1px 3px rgba(15,23,42,.06), 0 1px 2px rgba(15,23,42,.04);
  --shadow-md: 0 8px 22px rgba(15,23,42,.08);
  --shadow-lg: 0 18px 50px rgba(15,23,42,.18);
}

[data-theme="dark"] {
  --brand-blue: #93C5FD;
  --brand-orange: #FB923C;
  --primary: #60A5FA;
  --primary-dark: #3B82F6;
  --primary-light: #93C5FD;
  --accent: #FB923C;
  --accent-light: rgba(251,146,60,.12);
  --bg: #0D1117;
  --card: #161B22;
  --text: #E6EDF3;
  --text-muted: #9AA4B2;
  --border: #273244;
  --border-light: #212A39;
  --sidebar-bg: #080E19;
}

@media screen {
  body {
    background:
      linear-gradient(180deg, rgba(27,58,138,.045), rgba(247,148,29,.025) 260px, transparent 520px),
      var(--bg);
  }

  .breadcrumb {
    margin: 12px 12px 8px;
    border: 1px solid var(--border-light);
  }

  .topbar {
    min-height: 58px;
    height: auto;
    border: 1px solid var(--border-light);
    border-bottom: 3px solid var(--brand-blue);
    box-shadow: var(--shadow);
  }

  .topbar::before {
    content: "";
    width: 4px;
    align-self: stretch;
    border-radius: 999px;
    background: var(--brand-orange);
    margin-right: 2px;
  }

  .topbar-title {
    color: var(--primary-dark);
    font-size: 18px;
    line-height: 1.15;
  }

  [data-theme="dark"] .topbar-title,
  [data-theme="dark"] .card-title,
  [data-theme="dark"] .modal-title {
    color: var(--text);
  }

  .page-body {
    padding: 0 20px 24px;
  }

  .card,
  .kpi-card,
  .kpi-card-large,
  .status-card,
  .alert-group,
  .consertos-hero,
  .consertos-filterbar,
  .conserto-kpi,
  .kanban-col,
  .kanban-card {
    border-radius: var(--radius-lg);
    border-color: var(--border-light);
    box-shadow: var(--shadow);
  }

  .card:hover,
  .kpi-card:hover,
  .kpi-card-large:hover,
  .status-card:hover,
  .conserto-kpi:hover,
  .kanban-card:hover {
    border-color: var(--border);
    box-shadow: var(--shadow-md);
  }

  .card-title,
  .modal-title,
  .req-secao-titulo {
    color: var(--primary-dark);
  }

  .btn {
    min-height: 34px;
    border-radius: 8px;
  }

  .btn-primary {
    background: var(--primary-dark);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--primary);
  }

  .btn-outline,
  .btn-secondary {
    background: #fff;
    border: 1.5px solid rgba(27,58,138,.28);
    color: var(--primary-dark);
  }

  .btn-outline:hover,
  .btn-secondary:hover {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: #fff;
  }

  [data-theme="dark"] .btn-outline,
  [data-theme="dark"] .btn-secondary {
    background: rgba(255,255,255,.03);
    color: var(--primary-light);
    border-color: rgba(147,197,253,.35);
  }

  .btn-warning {
    background: var(--brand-orange);
  }

  .search-bar {
    min-height: 38px;
    background: #F8FAFC;
    border-color: var(--border);
  }

  [data-theme="dark"] .search-bar {
    background: rgba(255,255,255,.035);
  }

  input[type="text"],
  input[type="number"],
  input[type="email"],
  input[type="password"],
  input[type="date"],
  select,
  textarea {
    min-height: 36px;
    border-radius: 8px;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--brand-blue);
    box-shadow: 0 0 0 3px rgba(27,58,138,.10);
  }

  table {
    border-collapse: separate;
    border-spacing: 0;
  }

  thead th {
    background: #F8FAFC;
    color: #475569;
    border-bottom: 1px solid var(--border);
  }

  [data-theme="dark"] thead th {
    background: rgba(255,255,255,.035);
    color: var(--text-muted);
  }

  tbody td {
    border-bottom: 1px solid var(--border-light);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr:hover {
    background: rgba(27,58,138,.045);
  }

  .badge {
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .badge-low,
  .badge-PENDENTE {
    background: var(--accent-light);
    color: var(--accent-dark);
    border-color: rgba(247,148,29,.18);
  }

  .badge-pending,
  .badge-SOLICITADO {
    background: #EFF6FF;
    color: var(--primary-dark);
    border-color: rgba(27,58,138,.14);
  }

  .modal-overlay {
    padding: 14px;
    backdrop-filter: blur(4px);
  }

  .modal {
    border-radius: 12px;
    border: 1px solid var(--border-light);
  }

  .modal-header {
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 12px;
  }

  .modal-footer {
    border-top: 1px solid var(--border-light);
    padding-top: 14px;
  }

  .tabs,
  .module-tabs {
    background: transparent;
    border-bottom: 1px solid var(--border);
    gap: 4px;
  }

  .tab-btn.active,
  .module-tab.active {
    color: var(--primary-dark);
    border-bottom-color: var(--brand-orange);
    background: rgba(247,148,29,.08);
  }

  .req-secao,
  .form-section,
  .wizard-section {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border-light);
    border-left: 4px solid var(--brand-orange) !important;
    border-radius: 10px;
    box-shadow: var(--shadow);
  }

  .wizard-stack {
    display: grid;
    gap: 12px;
  }

  .wizard-section {
    padding: 14px 16px;
  }

  .wizard-section-title {
    margin-bottom: 12px;
    color: var(--primary-dark);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  #modal-peca .modal {
    width: min(920px, calc(100vw - 24px));
  }

  #modal-req .modal {
    max-width: 960px;
  }

  #modal-req form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  #modal-req form > input[type="hidden"],
  #modal-req form > .modal-footer {
    grid-column: 1 / -1;
  }

  #modal-req .req-secao:nth-of-type(3),
  #modal-req .req-secao:nth-of-type(5),
  #modal-req .req-secao:nth-of-type(7),
  #modal-req .req-secao:nth-of-type(9),
  #modal-req .req-secao:nth-of-type(10) {
    grid-column: 1 / -1;
  }

  .stock-detail-panel .card {
    border-top: 3px solid var(--brand-orange);
  }

  .stock-item-row.selected {
    background: rgba(27,58,138,.08) !important;
    box-shadow: inset 3px 0 0 var(--brand-orange);
  }

  .stock-bar-fill.low {
    background: var(--brand-orange);
  }

  .dashboard-kpi-grid,
  .kpi-grid {
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .kpi-card::before,
  .kpi-card-large::before {
    content: "";
    width: 4px;
    align-self: stretch;
    border-radius: 999px;
    background: var(--brand-orange);
    flex: 0 0 4px;
  }

  .kpi-icon.orange,
  .kpi-large-icon.orange {
    background: var(--accent-light);
    color: var(--brand-orange);
  }

  .module-tabs {
    margin: 0 12px 14px;
    padding: 0 8px;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    background: var(--card);
    box-shadow: var(--shadow);
  }

  .module-tab {
    margin-bottom: 0;
    border-bottom-width: 3px;
  }

  .consertos-hero {
    border-top: 3px solid var(--brand-orange);
  }

  .consertos-eyebrow,
  .kanban-num {
    color: var(--primary-dark);
  }

  .kanban-card {
    border-left-color: var(--brand-blue);
  }

  .kanban-card.is-overdue {
    border-left-color: var(--danger);
  }

  .kanban-card.is-done {
    border-left-color: var(--success);
  }

  .report-menu,
  .config-menu {
    position: sticky;
    top: 86px;
  }
}

@media screen and (max-width: 900px) {
  .topbar {
    margin: 0 8px 12px;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
  }

  .topbar::before {
    display: none;
  }

  .topbar-actions {
    width: 100%;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .page-body {
    padding: 0 12px 18px;
  }

  #modal-req form {
    display: block;
  }

  .stock-layout,
  .report-grid,
  .config-layout {
    display: block;
  }

  .stock-detail-panel {
    width: auto;
    position: static;
    margin-top: 14px;
  }

  .report-menu,
  .config-menu {
    position: static;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    margin-bottom: 14px;
  }
}

@media screen and (max-width: 680px) {
  .breadcrumb {
    display: none;
  }

  .dashboard-kpi-grid,
  .dashboard-status-grid,
  .alerts-grid,
  .kpi-grid {
    grid-template-columns: 1fr;
  }

  .modal {
    max-width: 100%;
    max-height: 96vh;
    padding: 18px;
  }

  .modal-footer {
    flex-direction: column-reverse;
  }

  .modal-footer .btn {
    width: 100%;
    justify-content: center;
  }

  .table-wrapper {
    border: 1px solid var(--border-light);
    border-radius: 10px;
  }
}

@media (max-width: 680px) {
  .breadcrumb {
    display: none;
  }

  .dashboard-kpi-grid,
  .dashboard-status-grid,
  .alerts-grid,
  .kpi-grid {
    grid-template-columns: 1fr;
  }

  .modal {
    max-width: 100%;
    max-height: 96vh;
    padding: 18px;
  }

  .modal-footer {
    flex-direction: column-reverse;
  }

  .modal-footer .btn {
    width: 100%;
    justify-content: center;
  }

  .table-wrapper {
    border: 1px solid var(--border-light);
    border-radius: 10px;
  }
}

/* â”€â”€ TEMA ESCURO â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
[data-theme="dark"] {
  --primary:       #60A5FA;
  --primary-dark:  #3B82F6;
  --primary-light: #93C5FD;
  --accent:        #FB923C;
  --accent-dark:   #EA580C;
  --accent-light:  rgba(249,115,22,0.10);
  --danger:        #F87171;
  --success:       #4ADE80;
  --warning:       #FCD34D;
  --info:          #38BDF8;
  --bg:            #0D1117;
  --card:          #161B22;
  --sidebar-bg:    #0A0F1A;
  --sidebar-text:  #8B949E;
  --sidebar-hover: rgba(255,255,255,0.06);
  --sidebar-active:rgba(255,255,255,0.04);
  --sidebar-accent:#FB923C;
  --text:          #E6EDF3;
  --text-muted:    #8B949E;
  --border:        #21262D;
  --border-light:  #30363D;
  --shadow:        0 1px 4px rgba(0,0,0,0.30), 0 1px 2px rgba(0,0,0,0.20);
  --shadow-md:     0 4px 12px rgba(0,0,0,0.40);
  --shadow-lg:     0 8px 28px rgba(0,0,0,0.50);
}

/* Sidebar dark mode â€” logo area ainda branca (logo Ã© colorida) */
[data-theme="dark"] .sidebar {
  background: #0A0F1A;
  border-right-color: rgba(251,146,60,0.20);
}

[data-theme="dark"] .sidebar-logo {
  background: #FFFFFF;    /* mantÃ©m branco â€” a logo Atlas Ã© colorida */
  border-bottom-color: #F7941D;
}

[data-theme="dark"] .sidebar-toggle {
  background: #1F2937;
  border-color: rgba(249,115,22,0.50);
  color: #F7941D;
}

[data-theme="dark"] .sidebar-toggle:hover {
  background: #F7941D;
  color: #fff;
}

[data-theme="dark"] .sidebar nav a.active {
  background: rgba(249,115,22,0.16);
}

[data-theme="dark"] .sidebar-footer {
  border-top-color: rgba(251,146,60,0.15);
}

[data-theme="dark"] .sidebar-footer .btn-logout {
  background: rgba(251,146,60,0.08);
  border-color: rgba(251,146,60,0.18);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* â”€â”€ LAYOUT PRINCIPAL â”€â”€ */
.app-layout {
  display: flex;
  min-height: 100vh;
  overflow-x: hidden;
  max-width: 100vw;
  width: 100%;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SIDEBAR â€” Redesign com identidade visual Atlas
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.sidebar {
  width: 200px;
  background: #111827;
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0;
  height: 100vh;
  z-index: 100;
  transition: width .22s cubic-bezier(.4,0,.2,1);
  overflow: hidden;
  /* Borda direita laranja suave â€” identidade da marca */
  border-right: 2px solid rgba(249,115,22,0.20);
}

/* â”€â”€ Ãrea da Logo â€” FUNDO BRANCO â”€â”€ */
.sidebar-logo {
  background: #FFFFFF;
  padding: 16px 18px 14px;
  border-bottom: 3px solid #F7941D;  /* linha laranja marca */
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.sidebar-logo .company { display: none; }

.sidebar-logo img.logo-img {
  max-height: 38px;
  max-width: 156px;
  object-fit: contain;
  display: block;
  margin-bottom: 4px;
}

.sidebar-logo .system-name {
  font-size: 11px;
  font-weight: 700;
  color: #1E293B;       /* texto escuro sobre fundo branco */
  margin-top: 2px;
  letter-spacing: 0.2px;
}

.sidebar-logo .sub {
  font-size: 10px;
  font-weight: 500;
  color: #F7941D;        /* sub em laranja da marca */
  letter-spacing: 0.3px;
  margin-top: 1px;
}

/* â”€â”€ Sidebar recolhida â”€â”€ */
.sidebar.collapsed {
  width: 56px;
}

.sidebar.collapsed .sidebar-logo {
  padding: 12px 0;
  align-items: center;
  border-bottom: 3px solid #F7941D;
}

.sidebar.collapsed .sidebar-logo img.logo-img {
  max-width: 34px;
  max-height: 34px;
  margin: 0;
}

.sidebar.collapsed .sidebar-logo .system-name,
.sidebar.collapsed .sidebar-logo .sub,
.sidebar.collapsed .nav-group-label,
.sidebar.collapsed nav a span:not(.icon),
.sidebar.collapsed .sidebar-footer .user-info,
.sidebar.collapsed .sidebar-footer .user-role,
.sidebar.collapsed .sidebar-footer .btn-logout {
  display: none;
}

.sidebar.collapsed nav a {
  padding: 10px 0;
  justify-content: center;
  gap: 0;
  border-left: 3px solid transparent;
  font-size: 0;
}

.sidebar.collapsed nav a .icon {
  font-size: 18px;
  min-width: auto;
}

.sidebar.collapsed .sidebar-footer {
  padding: 10px 0;
  display: flex;
  justify-content: center;
}

/* â”€â”€ BotÃ£o de toggle â”€â”€ */
.sidebar-toggle {
  position: absolute;
  top: 20px;
  right: -13px;
  width: 24px; height: 24px;
  background: #FFFFFF;
  border: 1.5px solid #F7941D;
  border-radius: 50%;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  z-index: 101;
  box-shadow: 0 2px 8px rgba(249,115,22,0.20);
  transition: background .15s, color .15s, transform .22s;
  color: #F7941D;
}
.sidebar-toggle:hover { background: #F7941D; color: #fff; }
.sidebar.collapsed .sidebar-toggle { transform: rotate(180deg); }

/* â”€â”€ NavegaÃ§Ã£o â”€â”€ */
.sidebar nav {
  flex: 1;
  padding: 8px 0;
  overflow-y: auto;
  overflow-x: hidden;
}

/* scrollbar fina */
.sidebar nav::-webkit-scrollbar { width: 3px; }
.sidebar nav::-webkit-scrollbar-track { background: transparent; }
.sidebar nav::-webkit-scrollbar-thumb { background: rgba(249,115,22,0.25); border-radius: 2px; }

.nav-group-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(249,115,22,0.50);   /* laranja suave para labels de grupo */
  padding: 10px 16px 3px;
  margin-top: 2px;
}

.sidebar nav a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  color: #9CA3AF;
  text-decoration: none;
  font-size: 12px;
  font-weight: 500;
  border-left: 3px solid transparent;
  transition: background .15s, border-color .15s, color .15s;
  border-radius: 0 6px 6px 0;
  margin-right: 8px;
}

.sidebar nav a:hover {
  background: rgba(249,115,22,0.08);
  color: #FFFFFF;
  border-left-color: rgba(249,115,22,0.50);
}

.sidebar nav a.active {
  background: rgba(249,115,22,0.14);   /* fundo laranja suave no item ativo */
  border-left-color: #F7941D;           /* borda laranja sÃ³lida */
  color: #FFFFFF;
  font-weight: 600;
}

/* Ãcone SVG no nav */
.sidebar nav a .icon {
  width: 16px;
  height: 16px;
  fill: currentColor;
  flex-shrink: 0;
  opacity: 0.85;
}

.sidebar nav a:hover .icon,
.sidebar nav a.active .icon { opacity: 1; }

/* SVG icons */
.sidebar nav a svg.icon {
  width: 20px;
  height: 20px;
  min-width: 20px;
  fill: currentColor;
  color: inherit;
}

/* â”€â”€ SeÃ§Ã£o AdministraÃ§Ã£o â€” destaque laranja â”€â”€ */
.nav-group-label.nav-admin {
  color: #F7941D !important;
  border-top: 1px solid rgba(249,115,22,0.20);
  margin-top: 6px;
  padding-top: 10px;
  opacity: 1;
}

/* â”€â”€ Footer do Sidebar â”€â”€ */
.sidebar-footer {
  padding: 12px 16px;
  border-top: 1px solid rgba(249,115,22,0.15);  /* linha laranja suave */
  font-size: 12px;
}

.sidebar-footer .user-info {
  font-weight: 700;
  color: #F3F4F6;
  font-size: 12px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sidebar-footer .user-role {
  font-size: 9px;
  color: #F7941D;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
  margin-top: 1px;
}

.sidebar-footer .btn-logout {
  margin-top: 8px;
  background: rgba(249,115,22,0.10);
  border: 1px solid rgba(249,115,22,0.20);
  color: #9CA3AF;
  padding: 6px 10px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 11px;
  width: 100%;
  transition: background .15s, color .15s, border-color .15s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.sidebar-footer .btn-logout svg.icon-logout {
  width: 14px;
  height: 14px;
  fill: currentColor;
}

.sidebar-footer .btn-logout:hover {
  background: var(--danger);
  border-color: var(--danger);
  color: #fff;
}

/* â”€â”€ CONTEÃšDO PRINCIPAL â”€â”€ */
.main-content {
  margin-left: 200px;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: calc(100vw - 200px);
  max-width: calc(100vw - 200px);
  overflow-x: hidden;
  transition: margin-left .22s cubic-bezier(.4,0,.2,1), max-width .22s cubic-bezier(.4,0,.2,1), width .22s cubic-bezier(.4,0,.2,1);
}

.sidebar.collapsed ~ .main-content {
  margin-left: 56px;
  width: calc(100vw - 56px);
  max-width: calc(100vw - 56px);
}

/* â”€â”€ BREADCRUMB â”€â”€ */
.breadcrumb {
  background: var(--card);
  padding: 9px 20px;
  font-size: 12px;
  color: var(--text-muted);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  box-shadow: var(--shadow);
}

.breadcrumb .bc-item {
  color: var(--primary);
  text-decoration: none;
  cursor: pointer;
  transition: color .15s;
}

.breadcrumb .bc-item:hover {
  color: var(--primary-light);
}

.breadcrumb .bc-separator {
  color: var(--border);
  opacity: 0.7;
}

.breadcrumb .bc-current {
  color: var(--text);
  font-weight: 600;
}

.topbar {
  background: var(--card);
  border-bottom: 2px solid var(--brand-blue);   /* azul Atlas como identidade visual */
  padding: 0 20px;
  height: 54px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 90;
  box-shadow: var(--shadow);
  margin: 0 12px 14px 12px;
  border-radius: var(--radius-lg);
}

.topbar-title { font-size: var(--text-lg); font-weight: 700; color: var(--brand-blue); letter-spacing: -0.2px; }
.topbar-subtitle { font-size: var(--text-xs); color: var(--text-muted); margin-top: 1px; }

.topbar-actions { display: flex; gap: 12px; align-items: center; }

.page-body {
  padding: 0 20px 20px;
  flex: 1;
  min-width: 0;
  overflow-x: hidden;
}

/* â”€â”€ CARDS â”€â”€ */
.card {
  background: var(--card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  padding: 20px 24px;
  border: 1px solid var(--border-light);
  transition: box-shadow .2s, border-color .2s;
}

.card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--border);
}

.card-title {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* â”€â”€ KPI CARDS â”€â”€ */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}

.kpi-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 18px 22px;
  box-shadow: var(--shadow);
  border: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  gap: 14px;
  transition: transform .2s cubic-bezier(.4,0,.2,1), box-shadow .2s, border-color .2s;
}

.kpi-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-light);
}

.kpi-icon {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
  background: var(--bg);
}

.kpi-icon.blue   { background: #EFF6FF; color: #2563EB; }
.kpi-icon.green  { background: #F0FDF4; color: #16A34A; }
.kpi-icon.orange { background: #FFF7ED; color: #F7941D; }
.kpi-icon.red    { background: #FEF2F2; color: #EF4444; }

[data-theme="dark"] .kpi-icon.blue   { background: rgba(93,148,255,0.12); }
[data-theme="dark"] .kpi-icon.green  { background: rgba(74,222,128,0.12); }
[data-theme="dark"] .kpi-icon.orange { background: rgba(249,115,22,0.12); }
[data-theme="dark"] .kpi-icon.red    { background: rgba(239,68,68,0.12); }

.kpi-value { font-size: 28px; font-weight: 800; color: var(--text); line-height: 1; letter-spacing: -0.5px; }
.kpi-label { font-size: 11px; color: var(--text-muted); margin-top: 3px; font-weight: 500; }

/* â”€â”€ TABELAS â”€â”€ */
.table-wrapper { overflow-x: auto; }
.stock-list-panel .table-wrapper { max-height: calc(100vh - 230px); overflow-y: auto; }

table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

thead th {
  background: var(--bg);
  color: var(--text-muted);
  font-weight: 600;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: .7px;
  padding: 10px 12px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
}

tbody tr {
  border-bottom: 1px solid var(--border-light);
  transition: background .12s;
  cursor: pointer;
}

tbody tr:hover { background: #F8FAFC; }
[data-theme="dark"] tbody tr:hover { background: rgba(93,148,255,0.06); }
tbody tr:last-child { border-bottom: none; }

tbody td { padding: 10px 12px; vertical-align: middle; font-size: var(--text-sm); }

/* â”€â”€ BADGES / STATUS â”€â”€ */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 9px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .2px;
  white-space: nowrap;
}

.badge-ok        { background: #F0FDF4; color: #16A34A; }
.badge-low       { background: #FEF3E2; color: #EA580C; }
.badge-critical  { background: #FEE2E2; color: #DC2626; }
.badge-pending   { background: #EFF6FF; color: #1D4ED8; }
.badge-approved  { background: #F0FDF4; color: #16A34A; }
.badge-rejected  { background: #FEE2E2; color: #DC2626; }
/* Status requisiÃ§Ãµes */
.badge-PENDENTE   { background: #FEF3E2; color: #EA580C; }
.badge-SOLICITADO { background: #EFF6FF; color: #1D4ED8; }
.badge-RECEBIDO   { background: #F0FDF4; color: #16A34A; }
.badge-REJEITADO  { background: #FEE2E2; color: #DC2626; }

[data-theme="dark"] .badge-ok      { background: rgba(74,222,128,0.12); }
[data-theme="dark"] .badge-low     { background: rgba(249,115,22,0.12); }
[data-theme="dark"] .badge-critical{ background: rgba(239,68,68,0.12); }
[data-theme="dark"] .badge-pending { background: rgba(93,148,255,0.12); }
[data-theme="dark"] .badge-approved{ background: rgba(74,222,128,0.12); }
[data-theme="dark"] .badge-rejected{ background: rgba(239,68,68,0.12); }

/* â”€â”€ BOTÃ•ES â”€â”€ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all .18s cubic-bezier(.4,0,.2,1);
  text-decoration: none;
  letter-spacing: 0.1px;
}

.btn-primary   { background: var(--primary); color: #fff; }
.btn-primary:hover { background: var(--primary-dark); box-shadow: 0 2px 8px rgba(37,99,235,0.25); }

.btn-success   { background: var(--success); color: #fff; }
.btn-success:hover { background: #16A34A; box-shadow: 0 2px 8px rgba(34,197,94,0.25); }

.btn-danger    { background: var(--danger); color: #fff; }
.btn-danger:hover { background: #DC2626; box-shadow: 0 2px 8px rgba(239,68,68,0.25); }

.btn-warning   { background: var(--warning); color: #fff; }
.btn-warning:hover { background: #D97706; box-shadow: 0 2px 8px rgba(245,158,11,0.25); }

.btn-outline   { background: transparent; color: var(--primary); border: 1.5px solid var(--primary); }
.btn-outline:hover { background: var(--primary); color: #fff; }

.btn-sm { padding: 5px 12px; font-size: 12px; }
.btn-icon { padding: 7px; border-radius: 8px; background: var(--card); border: 1px solid var(--border); cursor: pointer; font-size: 14px; transition: all .15s; }
.btn-icon:hover { background: var(--bg); border-color: var(--primary); }

/* â”€â”€ FORMULÃRIOS â”€â”€ */
.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 18px;
}

.form-group { display: flex; flex-direction: column; gap: 7px; }
.form-group.full { grid-column: 1 / -1; }

label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: .6px;
}

input[type="text"],
input[type="number"],
input[type="email"],
input[type="password"],
input[type="date"],
select,
textarea {
  padding: 8px 12px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-size: var(--text-base);
  font-family: var(--font);
  color: var(--text);
  background: var(--card);
  transition: border-color .15s, box-shadow .15s;
  outline: none;
}

input:focus, select:focus, textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
}

textarea { resize: vertical; min-height: 100px; }

/* â”€â”€ SEARCH BAR â”€â”€ */
.search-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 10px 14px;
}

.search-bar input {
  border: none;
  background: transparent;
  outline: none;
  font-size: var(--text-base);
  color: var(--text);
  flex: 1;
  padding: 0;
}

.search-bar .icon { color: var(--text-muted); font-size: 16px; }

/* â”€â”€ ITEM DE ESTOQUE COM IMAGEM â”€â”€ */
.stock-layout { display: flex; gap: 22px; align-items: flex-start; }

.stock-list-panel { flex: 1; min-width: 0; }

.stock-detail-panel {
  width: 260px;
  flex-shrink: 0;
  position: sticky;
  top: 78px;
}

.stock-item-row { cursor: pointer; }
.stock-item-row.selected { background: #e8f0fe !important; }

.item-photo-box {
  width: 100%;
  aspect-ratio: 4/3;
  border-radius: 10px;
  overflow: hidden;
  background: var(--bg);
  border: 2px dashed var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
  position: relative;
}

.item-photo-box img {
  width: 100%; height: 100%;
  object-fit: contain;
  padding: 8px;
}

.item-photo-box .no-photo {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: var(--text-muted);
  font-size: 13px;
}

.item-photo-box .no-photo span { font-size: 36px; opacity: .4; }

.item-detail-info { display: flex; flex-direction: column; gap: 8px; }

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}

.detail-row:last-child { border-bottom: none; }
.detail-label { color: var(--text-muted); font-size: 11px; font-weight: 600; text-transform: uppercase; }
.detail-value { font-weight: 600; color: var(--text); }

/* â”€â”€ ALERTAS â”€â”€ */
.alert {
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 12px;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-left: 3px solid;
}

.alert-warning { background: #FEF3E2; border-left-color: var(--warning); color: #92400E; }
.alert-danger  { background: #FEE2E2; border-left-color: var(--danger);  color: #7C2D12; }
.alert-success { background: #F0FDF4; border-left-color: var(--success); color: #166534; }
.alert-info    { background: #EFF6FF; border-left-color: var(--info);    color: #0C4A6E; }

[data-theme="dark"] .alert-warning { background: rgba(249,115,22,0.12); color: var(--warning); }
[data-theme="dark"] .alert-danger  { background: rgba(239,68,68,0.12);  color: var(--danger); }
[data-theme="dark"] .alert-success { background: rgba(74,222,128,0.12); color: var(--success); }
[data-theme="dark"] .alert-info    { background: rgba(93,148,255,0.12); color: var(--info); }

/* â”€â”€ MODAL â”€â”€ */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.40);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
  opacity: 0; pointer-events: none;
  transition: opacity .2s;
  backdrop-filter: blur(2px);
}

.modal-overlay.open { opacity: 1; pointer-events: all; }

.modal {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 24px 28px;
  width: 100%;
  max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-lg);
  transform: translateY(16px);
  transition: transform .2s;
  border: 1px solid var(--border-light);
}

.modal-overlay.open .modal { transform: translateY(0); }

.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18px;
}

.modal-title { font-size: var(--text-base); font-weight: 700; color: var(--text); }

.modal-close {
  background: none; border: none; cursor: pointer;
  font-size: 20px; color: var(--text-muted); line-height: 1;
  padding: 6px;
  border-radius: 8px;
  transition: background .15s;
}
.modal-close:hover { background: var(--bg); color: var(--text); }

.modal-footer {
  margin-top: 20px;
  display: flex; gap: 10px; justify-content: flex-end;
}

/* â”€â”€ MINI CHART BARS â”€â”€ */
.mini-bar-chart { display: flex; align-items: flex-end; gap: 4px; height: 48px; }
.mini-bar { flex: 1; background: var(--primary-light); border-radius: 3px 3px 0 0; opacity: .7; transition: opacity .15s; }
.mini-bar:hover { opacity: 1; }

/* â”€â”€ TABS â”€â”€ */
.tabs { display: flex; gap: 2px; border-bottom: 1.5px solid var(--border); margin-bottom: 16px; }
.tab-btn {
  padding: 7px 14px;
  font-size: 12px; font-weight: 600;
  border: none; background: none; cursor: pointer;
  color: var(--text-muted);
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  border-radius: 6px 6px 0 0;
  transition: color .15s, border-color .15s;
}
.tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
.tab-btn:hover:not(.active) { color: var(--text); background: var(--bg); }

/* â”€â”€ TOAST NOTIFICATION â”€â”€ */
#toast-container {
  position: fixed; bottom: 24px; right: 24px;
  z-index: 9999; display: flex; flex-direction: column; gap: 8px;
}

.toast {
  background: #1E293B;
  color: #F1F5F9;
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 12px;
  min-width: 240px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.20);
  display: flex; align-items: center; gap: 8px;
  animation: slideIn .25s ease;
}

.toast.success { border-left: 4px solid var(--success); }
.toast.error   { border-left: 4px solid var(--danger); }
.toast.warning { border-left: 4px solid var(--warning); }
.toast.info    { border-left: 4px solid var(--info); }

@keyframes slideIn { from { opacity:0; transform: translateX(30px); } to { opacity:1; transform: translateX(0); } }

/* â”€â”€ UPLOAD IMAGEM â”€â”€ */
.img-upload-area {
  border: 2px dashed var(--primary-light);
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  cursor: pointer;
  transition: background .15s, border-color .15s;
  background: #f5f8ff;
}

.img-upload-area:hover { background: #e8f0fe; border-color: var(--primary); }
.img-upload-area .icon { font-size: 32px; margin-bottom: 6px; }
.img-upload-area p { font-size: 13px; color: var(--text-muted); }
.img-upload-area .preview { max-height: 160px; border-radius: 8px; margin-top: 10px; max-width: 100%; object-fit: contain; }

/* â”€â”€ GALERIA DE FOTOS (modal ediÃ§Ã£o) â”€â”€ */
.foto-galeria {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: flex-start;
  min-height: 108px;
  padding: 10px;
  background: #f5f8ff;
  border: 2px dashed var(--primary-light);
  border-radius: 10px;
}
.foto-galeria-thumb {
  position: relative;
  width: 90px; height: 90px;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid var(--border);
  transition: border-color .15s, transform .12s;
  flex-shrink: 0;
}
.foto-galeria-thumb:hover { border-color: var(--primary); transform: scale(1.04); }
.foto-galeria-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.foto-galeria-thumb .del-foto {
  position: absolute; top: 3px; right: 3px;
  background: rgba(220,53,69,.88); color: #fff;
  border: none; border-radius: 50%;
  width: 20px; height: 20px;
  font-size: 10px; font-weight: 700; line-height: 1;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity .15s;
  z-index: 2;
}
.foto-galeria-thumb:hover .del-foto { opacity: 1; }
.foto-galeria-upload-btn {
  width: 90px; height: 90px;
  border-radius: 8px;
  border: 2px dashed var(--border);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 3px;
  cursor: pointer;
  color: var(--text-muted); font-size: 11px;
  transition: border-color .15s, color .15s;
  flex-shrink: 0;
  background: transparent;
}
.foto-galeria-upload-btn:hover { border-color: var(--primary); color: var(--primary); }
.foto-galeria-upload-btn .icon { font-size: 22px; margin: 0; }
.foto-galeria-upload-btn.enviando { opacity: .6; pointer-events: none; }
/* Galeria no painel de detalhe (estoque) */
.detalhe-galeria-wrap { margin-bottom: 0; }
.detalhe-foto-principal {
  width: 100%; background: var(--bg);
  border-radius: 8px; overflow: hidden;
  margin-bottom: 6px;
  max-height: 200px;
  display: flex; align-items: center; justify-content: center;
}
.detalhe-foto-principal img {
  max-width: 100%; max-height: 200px;
  object-fit: contain; cursor: zoom-in;
  display: block;
}
.detalhe-foto-strip {
  display: flex; gap: 5px; flex-wrap: wrap;
}
.detalhe-foto-strip img {
  width: 52px; height: 52px;
  object-fit: cover; border-radius: 6px;
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color .12s, transform .1s;
}
.detalhe-foto-strip img:hover,
.detalhe-foto-strip img.ativa { border-color: var(--primary); transform: scale(1.08); }
[data-theme="dark"] .foto-galeria { background: var(--card); border-color: var(--border); }

/* â”€â”€ ESTOQUE MÃNIMO PROGRESS BAR â”€â”€ */
.stock-bar-wrap { display: flex; align-items: center; gap: 8px; }
.stock-bar { flex: 1; height: 6px; border-radius: 3px; background: var(--border); overflow: hidden; }
.stock-bar-fill { height: 100%; border-radius: 3px; transition: width .3s; }
.stock-bar-fill.ok       { background: var(--success); }
.stock-bar-fill.low      { background: var(--warning); }
.stock-bar-fill.critical { background: var(--danger); }

/* â”€â”€ RESPONSIVIDADE â”€â”€ */
@media (max-width: 900px) {
  .sidebar { width: 180px; }
  .main-content { margin-left: 180px; width: calc(100vw - 180px); max-width: calc(100vw - 180px); }
  .stock-detail-panel { width: 220px; }
}

@media (max-width: 680px) {
  .sidebar { display: none; }
  .main-content { margin-left: 0; max-width: 100vw; }
  .stock-layout { flex-direction: column; }
  .stock-detail-panel { width: 100%; position: static; }
  .kpi-grid { grid-template-columns: 1fr 1fr; }
}

/* â”€â”€ SCROLLBAR â”€â”€ */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #b0bec5; }

/* â”€â”€ LOGIN PAGE â”€â”€ */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0F172A 0%, #1D4ED8 50%, #3B7FE4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-box {
  background: #fff;
  border-radius: 16px;
  padding: 36px 40px;
  width: 100%;
  max-width: 400px;
  box-shadow: 0 16px 48px rgba(15,23,42,0.18);
  border-top: 4px solid #F7941D;
}

.login-logo { text-align: center; margin-bottom: 24px; }
.login-logo .company { font-size: 11px; font-weight: 700; color: #F7941D; letter-spacing: 1.8px; text-transform: uppercase; }
.login-logo .system  { font-size: 20px; font-weight: 800; color: #111827; margin-top: 4px; }
.login-logo .sub     { font-size: 12px; color: #6B7280; margin-top: 3px; }

.login-box h2 { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 20px; text-align: center; }

.login-box .form-group { margin-bottom: 14px; }
.login-box label { display: block; margin-bottom: 6px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .6px; }
.login-box input { width: 100%; }

.login-btn {
  width: 100%;
  padding: 11px;
  background: var(--primary);
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 6px;
  transition: all .2s;
}

.login-btn:hover {
  background: var(--primary-dark);
  box-shadow: 0 4px 16px rgba(37,99,235,0.28);
}

.login-error { color: var(--danger); font-size: 12px; text-align: center; margin-top: 10px; display: none; }

/* â”€â”€ SECTION TITLES â”€â”€ */
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
  flex-wrap: wrap; gap: 8px;
}

.section-title { font-size: 13px; font-weight: 700; color: var(--text); }
.section-sub   { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

/* â”€â”€ EMPTY STATE â”€â”€ */
.empty-state {
  text-align: center;
  padding: 36px 24px;
  color: var(--text-muted);
}
.empty-state .icon { font-size: 36px; margin-bottom: 8px; opacity: .4; }
.empty-state p { font-size: 13px; }

/* â”€â”€ DIVIDER â”€â”€ */
.divider { border: none; border-top: 1px solid var(--border); margin: 18px 0; }

/* â”€â”€ DARK MODE: FORMS / TOPBAR / SEARCH â”€â”€ */
[data-theme="dark"] thead th { background: var(--bg); }
[data-theme="dark"] .search-bar { background: var(--bg); border-color: var(--border); }
[data-theme="dark"] .search-bar input { background: transparent; }
[data-theme="dark"] .img-upload-area { background: var(--card); border-color: var(--border); }
[data-theme="dark"] .img-upload-area:hover { background: rgba(59,125,232,0.08); }
[data-theme="dark"] .login-box { background: var(--card); border-top-color: #F7941D; }
[data-theme="dark"] .login-page { background: linear-gradient(145deg, #04091A 0%, #0A1540 55%, #0C1E5B 100%); }
[data-theme="dark"] code { background: var(--bg); color: var(--primary-light); }

/* â”€â”€ TEMA TOGGLE BUTTON â”€â”€ */
.btn-theme {
  background: var(--card);
  border: 1.5px solid var(--border);
  color: var(--text-muted);
  width: 34px;
  height: 34px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 15px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
  flex-shrink: 0;
}

.btn-theme:hover {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* â”€â”€ KPI CARD CLICÃVEL â”€â”€ */
.kpi-card.clickable { cursor: pointer; }
.kpi-card.clickable:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--primary-light); }

/* â”€â”€ REPORT â”€â”€ */
.report-grid { display: grid; grid-template-columns: 240px 1fr; gap: 22px; }
.report-menu { display: flex; flex-direction: column; gap: 6px; }
.report-menu-item {
  display: flex; align-items: center; gap: 12px; padding: 12px 16px;
  border-radius: var(--radius); cursor: pointer; border: 1.5px solid var(--border);
  background: var(--card); text-decoration: none; color: var(--text); transition: all .15s;
}
.report-menu-item:hover { border-color: var(--primary); background: rgba(30,58,95,0.05); }
[data-theme="dark"] .report-menu-item:hover { background: rgba(59,125,232,0.08); }
.report-menu-item.active { border-color: var(--primary); background: rgba(30,58,95,0.08); color: var(--primary); font-weight: 700; }
[data-theme="dark"] .report-menu-item.active { background: rgba(59,125,232,0.12); }
.report-menu-item .r-icon { font-size: 20px; flex-shrink: 0; }
.report-menu-item .r-info .r-title { font-size: 13.5px; font-weight: 600; }
.report-menu-item .r-info .r-desc  { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

/* â”€â”€ ETIQUETA PREVIEW (TELA) â”€â”€ */
.etiqueta-grid-screen {
  display: grid; grid-template-columns: repeat(auto-fill, 340px); gap: 12px; margin-top: 16px;
}
.etiqueta-preview {
  width: 340px; height: 151px; border: 1.5px solid var(--border); border-radius: 8px;
  padding: 10px 12px; display: flex; gap: 10px; align-items: center;
  background: var(--card); overflow: hidden;
}
.etiqueta-preview .qr-area { flex-shrink: 0; width: 110px; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.etiqueta-preview .info-area { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.etiqueta-preview .e-nome  { font-size: 12px; font-weight: 700; line-height: 1.3; overflow: hidden; }
.etiqueta-preview .e-code  { font-size: 11px; font-family: var(--font-mono); background: var(--bg); padding: 1px 6px; border-radius: 4px; }
.etiqueta-preview .e-local { font-size: 11px; color: var(--text-muted); }
.etiqueta-preview .e-logo  { max-height: 20px; max-width: 80px; object-fit: contain; opacity: .7; }

/* â”€â”€ DROP ZONE (IMPORT) â”€â”€ */
.drop-zone {
  border: 2px dashed var(--border); border-radius: var(--radius);
  padding: 32px; text-align: center; cursor: pointer; transition: all .2s;
  background: var(--card);
}
.drop-zone:hover, .drop-zone.dragover { border-color: var(--primary); background: rgba(30,58,95,0.05); }
[data-theme="dark"] .drop-zone:hover  { background: rgba(59,125,232,0.08); }
.drop-zone .dz-icon { font-size: 36px; margin-bottom: 10px; opacity: .4; }
.drop-zone p { font-size: 13px; color: var(--text-muted); }

/* â”€â”€ CONFIG TABS â”€â”€ */
.config-layout { display: grid; grid-template-columns: 200px 1fr; gap: 22px; }
.config-menu { display: flex; flex-direction: column; gap: 4px; }
.config-menu-item {
  display: flex; align-items: center; gap: 10px; padding: 11px 14px;
  border-radius: var(--radius); cursor: pointer; font-size: 14px; font-weight: 500;
  color: var(--text-muted); transition: all .15s; border: none; background: none; text-align: left;
}
.config-menu-item:hover { background: var(--bg); color: var(--text); }
.config-menu-item.active { background: rgba(30,58,95,0.08); color: var(--primary); font-weight: 700; }
[data-theme="dark"] .config-menu-item.active { background: rgba(59,125,232,0.12); }
/* .config-panel uses dynamic innerHTML â€” always visible, no display toggle needed */

/* â”€â”€ PRINT: LABELS â”€â”€ */
@media print {
  .no-print { display: none !important; }
  body, html { background: white !important; }
  .print-only { display: block !important; }
  .labels-sheet { margin: 0; padding: 8mm; }
  .labels-grid {
    display: grid;
    grid-template-columns: 90mm 90mm;
    gap: 3mm 8mm;
  }
  .label-item {
    width: 90mm; height: 40mm;
    border: 0.5pt solid #bbb; border-radius: 2pt;
    padding: 2.5mm 3mm; display: flex; gap: 2mm;
    align-items: center; overflow: hidden;
    page-break-inside: avoid; box-sizing: border-box;
  }
  .label-qr-col { width: 30mm; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 1mm; }
  .label-qr-col canvas, .label-qr-col img { width: 26mm !important; height: 26mm !important; }
  .label-info-col { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; gap: 1.5mm; }
  .label-logo { max-height: 7mm; max-width: 35mm; object-fit: contain; }
  .label-nome  { font-size: 7.5pt; font-weight: 700; line-height: 1.2; }
  .label-code  { font-size: 7pt; font-family: monospace; }
  .label-local { font-size: 6.5pt; color: #555; }
}
.print-only { display: none; }

/* â”€â”€ PRINT: REPORTS â”€â”€ */
@media print {
  .report-header-print { border-bottom: 2pt solid var(--primary, #1e3a5f); padding-bottom: 8pt; margin-bottom: 14pt; }
  .report-grid, .config-layout { display: block; }
  .report-menu, .config-menu { display: none; }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   IMPRESSÃƒO PROFISSIONAL â€” aplicado a TODOS os relatÃ³rios
   e documentos do sistema
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
@media print {
  @page {
    size: A4 portrait;
    margin: 14mm 16mm 18mm 16mm;
  }

  /* Reset geral de cores para branco/preto */
  *, *::before, *::after {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
    color-adjust: exact !important;
  }

  html, body {
    background: #fff !important;
    color: #000 !important;
    font-size: 10pt !important;
    font-family: Arial, Helvetica, sans-serif !important;
  }

  /* ForÃ§ar variÃ¡veis CSS para modo light mesmo em dark mode */
  [data-theme="dark"] {
    --text:       #111 !important;
    --text-muted: #555 !important;
    --bg:         #f5f5f5 !important;
    --card:       #fff !important;
    --border:     #ccc !important;
    --primary:    #1e3a5f !important;
    --success:    #2e7d32 !important;
    --danger:     #c62828 !important;
    --warning:    #e65100 !important;
  }

  /* Tabelas â€” bordas limpas */
  table {
    width: 100% !important;
    border-collapse: collapse !important;
    font-size: 8.5pt !important;
    page-break-inside: auto;
  }
  thead { display: table-header-group; }
  tr    { page-break-inside: avoid; }
  th {
    background: #1e3a5f !important;
    color: #fff !important;
    padding: 5pt 7pt !important;
    text-align: left !important;
    font-size: 7.5pt !important;
    font-weight: 700 !important;
    border: 0.5pt solid #1e3a5f !important;
  }
  td {
    padding: 4.5pt 7pt !important;
    border: 0.5pt solid #ccc !important;
    vertical-align: top !important;
    color: #111 !important;
    background: #fff !important;
  }
  tr:nth-child(even) td { background: #f7f9fb !important; }

  /* Badges simplificados para impressÃ£o */
  .badge {
    font-size: 7pt !important;
    font-weight: 700 !important;
    padding: 1pt 5pt !important;
    border-radius: 3pt !important;
    border: 0.5pt solid currentColor !important;
    background: transparent !important;
  }
  .badge-ok       { color: #2e7d32 !important; border-color: #2e7d32 !important; }
  .badge-low      { color: #e65100 !important; border-color: #e65100 !important; }
  .badge-critical { color: #c62828 !important; border-color: #c62828 !important; }

  /* KPI cards */
  .sumario-kpi {
    background: #f5f8fc !important;
    border: 0.5pt solid #c0cfe0 !important;
    border-radius: 4pt !important;
  }
  .sumario-kpi-val { font-size: 16pt !important; font-weight: 800 !important; color: #1e3a5f !important; }
  .sumario-kpi-lbl { font-size: 7pt !important; color: #555 !important; }

  /* CabeÃ§alho de relatÃ³rio */
  .relatorio-header {
    border-bottom: 1.5pt solid #1e3a5f !important;
    margin-bottom: 12pt !important;
    padding-bottom: 8pt !important;
  }
  .relatorio-titulo   { font-size: 14pt !important; font-weight: 800 !important; color: #1e3a5f !important; }
  .relatorio-subtitle { font-size: 8pt !important; color: #555 !important; }

  /* CabeÃ§alho da empresa (print-header) */
  .print-header {
    display: flex !important;
    align-items: center !important;
    gap: 14pt !important;
    border-bottom: 2pt solid #1e3a5f !important;
    padding-bottom: 10pt !important;
    margin-bottom: 16pt !important;
  }
  .print-header .print-logo { max-height: 45pt !important; max-width: 100pt !important; }
  .print-header .print-report-name { font-size: 15pt !important; font-weight: 800 !important; color: #1e3a5f !important; }
  .print-header .print-date        { font-size: 8pt !important; color: #555 !important; }

  /* RodapÃ© de pÃ¡gina com numeraÃ§Ã£o */
  body::after {
    content: "Atlas PCM Almoxarifado  Â·  " attr(data-empresa) "  Â·  Impresso em " attr(data-print-date);
    position: fixed;
    bottom: 8mm;
    left: 16mm;
    right: 16mm;
    text-align: center;
    font-size: 7pt;
    color: #888;
    border-top: 0.5pt solid #ccc;
    padding-top: 4pt;
  }

  /* Ocultar elementos de UI */
  .sidebar, .topbar, .no-print,
  .relatorio-menu, .config-menu,
  .filtro-row, button:not(.print-btn) { display: none !important; }

  /* ForÃ§ar largura total */
  .app-layout      { display: block !important; }
  .main-content    { padding: 0 !important; margin: 0 !important; width: 100% !important; }
  .page-body       { padding: 0 !important; }
  .relatorio-layout { display: block !important; }
  .relatorio-panel { border: none !important; padding: 0 !important; box-shadow: none !important; }

  /* table-wrapper sem overflow no print */
  .table-wrapper { overflow: visible !important; }

  /* code inline */
  code {
    background: #eef2f7 !important;
    color: #1e3a5f !important;
    font-size: 7.5pt !important;
    padding: 1pt 4pt !important;
    border-radius: 2pt !important;
  }
}

/* =========================================================
   REFATORACAO VISUAL 2026 — override final pos-impressao
   ========================================================= */

@media screen {
  :root {
    --brand-blue: #1B3A8A;
    --brand-orange: #F7941D;
    --primary: #2563EB;
    --primary-dark: #1B3A8A;
    --primary-light: #93B4FF;
    --accent: #F7941D;
    --accent-dark: #D97706;
    --accent-light: #FFF7ED;
    --bg: #F1F4F8;
    --card: #FFFFFF;
    --text: #1E293B;
    --text-muted: #64748B;
    --border: #E2E8F0;
    --border-light: #EEF2F7;
    --sidebar-bg: #101827;
    --radius: 8px;
    --radius-lg: 10px;
    --shadow: 0 1px 3px rgba(15,23,42,.06), 0 1px 2px rgba(15,23,42,.04);
    --shadow-md: 0 8px 22px rgba(15,23,42,.08);
    --shadow-lg: 0 18px 50px rgba(15,23,42,.18);
  }

  [data-theme="dark"] {
    --brand-blue: #93C5FD;
    --brand-orange: #FB923C;
    --primary: #60A5FA;
    --primary-dark: #3B82F6;
    --primary-light: #93C5FD;
    --accent: #FB923C;
    --accent-light: rgba(251,146,60,.12);
    --bg: #0D1117;
    --card: #161B22;
    --text: #E6EDF3;
    --text-muted: #9AA4B2;
    --border: #273244;
    --border-light: #212A39;
    --sidebar-bg: #080E19;
  }

  body {
    background:
      linear-gradient(180deg, rgba(27,58,138,.045), rgba(247,148,29,.025) 260px, transparent 520px),
      var(--bg);
  }

  .breadcrumb {
    margin: 12px 12px 8px;
    border: 1px solid var(--border-light);
  }

  .topbar {
    min-height: 58px;
    height: auto;
    border: 1px solid var(--border-light);
    border-bottom: 3px solid var(--brand-blue);
    box-shadow: var(--shadow);
  }

  .topbar::before {
    content: "";
    width: 4px;
    align-self: stretch;
    border-radius: 999px;
    background: var(--brand-orange);
    margin-right: 2px;
  }

  .topbar-title {
    color: var(--primary-dark);
    font-size: 18px;
    line-height: 1.15;
  }

  [data-theme="dark"] .topbar-title,
  [data-theme="dark"] .card-title,
  [data-theme="dark"] .modal-title {
    color: var(--text);
  }

  .page-body {
    padding: 0 20px 24px;
  }

  .card,
  .kpi-card,
  .kpi-card-large,
  .status-card,
  .alert-group,
  .consertos-hero,
  .consertos-filterbar,
  .conserto-kpi,
  .kanban-col,
  .kanban-card {
    border-radius: var(--radius-lg);
    border-color: var(--border-light);
    box-shadow: var(--shadow);
  }

  .card:hover,
  .kpi-card:hover,
  .kpi-card-large:hover,
  .status-card:hover,
  .conserto-kpi:hover,
  .kanban-card:hover {
    border-color: var(--border);
    box-shadow: var(--shadow-md);
  }

  .card-title,
  .modal-title,
  .req-secao-titulo {
    color: var(--primary-dark);
  }

  .btn {
    min-height: 34px;
    border-radius: 8px;
  }

  .btn-primary {
    background: var(--primary-dark);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--primary);
  }

  .btn-outline,
  .btn-secondary {
    background: #fff;
    border: 1.5px solid rgba(27,58,138,.28);
    color: var(--primary-dark);
  }

  .btn-outline:hover,
  .btn-secondary:hover {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: #fff;
  }

  [data-theme="dark"] .btn-outline,
  [data-theme="dark"] .btn-secondary {
    background: rgba(255,255,255,.03);
    color: var(--primary-light);
    border-color: rgba(147,197,253,.35);
  }

  .search-bar {
    min-height: 38px;
    background: #F8FAFC;
    border-color: var(--border);
  }

  [data-theme="dark"] .search-bar {
    background: rgba(255,255,255,.035);
  }

  input[type="text"],
  input[type="number"],
  input[type="email"],
  input[type="password"],
  input[type="date"],
  select,
  textarea {
    min-height: 36px;
    border-radius: 8px;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--brand-blue);
    box-shadow: 0 0 0 3px rgba(27,58,138,.10);
  }

  table {
    border-collapse: separate;
    border-spacing: 0;
  }

  thead th {
    background: #F8FAFC;
    color: #475569;
    border-bottom: 1px solid var(--border);
  }

  [data-theme="dark"] thead th {
    background: rgba(255,255,255,.035);
    color: var(--text-muted);
  }

  tbody td {
    border-bottom: 1px solid var(--border-light);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr:hover {
    background: rgba(27,58,138,.045);
  }

  .badge {
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .badge-low,
  .badge-PENDENTE {
    background: var(--accent-light);
    color: var(--accent-dark);
    border-color: rgba(247,148,29,.18);
  }

  .badge-pending,
  .badge-SOLICITADO {
    background: #EFF6FF;
    color: var(--primary-dark);
    border-color: rgba(27,58,138,.14);
  }

  .modal-overlay {
    padding: 14px;
    backdrop-filter: blur(4px);
  }

  .modal {
    border-radius: 12px;
    border: 1px solid var(--border-light);
  }

  .modal-header {
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 12px;
  }

  .modal-footer {
    border-top: 1px solid var(--border-light);
    padding-top: 14px;
  }

  .tab-btn.active,
  .module-tab.active {
    color: var(--primary-dark);
    border-bottom-color: var(--brand-orange);
    background: rgba(247,148,29,.08);
  }

  .req-secao,
  .form-section,
  .wizard-section {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border-light);
    border-left: 4px solid var(--brand-orange) !important;
    border-radius: 10px;
    box-shadow: var(--shadow);
  }

  #modal-req .modal {
    max-width: 960px;
  }

  #modal-req form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  #modal-req form > input[type="hidden"],
  #modal-req form > .modal-footer {
    grid-column: 1 / -1;
  }

  #modal-req .req-secao:nth-of-type(3),
  #modal-req .req-secao:nth-of-type(5),
  #modal-req .req-secao:nth-of-type(7),
  #modal-req .req-secao:nth-of-type(9),
  #modal-req .req-secao:nth-of-type(10) {
    grid-column: 1 / -1;
  }

  .stock-detail-panel .card {
    border-top: 3px solid var(--brand-orange);
  }

  .stock-item-row.selected {
    background: rgba(27,58,138,.08) !important;
    box-shadow: inset 3px 0 0 var(--brand-orange);
  }

  .dashboard-kpi-grid,
  .kpi-grid {
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .kpi-card::before,
  .kpi-card-large::before {
    content: "";
    width: 4px;
    align-self: stretch;
    border-radius: 999px;
    background: var(--brand-orange);
    flex: 0 0 4px;
  }

  .module-tabs {
    margin: 0 12px 14px;
    padding: 0 8px;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    background: var(--card);
    box-shadow: var(--shadow);
  }

  .module-tab {
    margin-bottom: 0;
    border-bottom-width: 3px;
  }

  .consertos-hero {
    border-top: 3px solid var(--brand-orange);
  }

  .consertos-eyebrow,
  .kanban-num {
    color: var(--primary-dark);
  }

  .kanban-card {
    border-left-color: var(--brand-blue);
  }

  .kanban-card.is-overdue {
    border-left-color: var(--danger);
  }

  .kanban-card.is-done {
    border-left-color: var(--success);
  }

  .report-menu,
  .config-menu {
    position: sticky;
    top: 86px;
  }
}

@media screen and (max-width: 900px) {
  .topbar {
    margin: 0 8px 12px;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
  }

  .topbar::before {
    display: none;
  }

  .topbar-actions {
    width: 100%;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .page-body {
    padding: 0 12px 18px;
  }

  #modal-req form {
    display: block;
  }

  .stock-layout,
  .report-grid,
  .config-layout {
    display: block;
  }

  .stock-detail-panel {
    width: auto;
    position: static;
    margin-top: 14px;
  }

  .report-menu,
  .config-menu {
    position: static;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    margin-bottom: 14px;
  }
}

@media screen and (max-width: 680px) {
  .breadcrumb {
    display: none;
  }

  .dashboard-kpi-grid,
  .dashboard-status-grid,
  .alerts-grid,
  .kpi-grid {
    grid-template-columns: 1fr;
  }

  .modal {
    max-width: 100%;
    max-height: 96vh;
    padding: 18px;
  }

  .modal-footer {
    flex-direction: column-reverse;
  }

  .modal-footer .btn {
    width: 100%;
    justify-content: center;
  }

  .table-wrapper {
    border: 1px solid var(--border-light);
    border-radius: 10px;
  }
}

